# RecipeCrave environment variables — copy to .env.local and fill values.
# Never commit .env.local.

# === Public site config ===
NEXT_PUBLIC_SITE_URL=https://recipecrave.com
NEXT_PUBLIC_SITE_NAME=RecipeCrave

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# === AI Providers ===
GOOGLE_GEMINI_API_KEY=
GROQ_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# === USDA Nutrition ===
USDA_API_KEY=

# === Email ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@recipecrave.com

# === Analytics ===
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Sentry ===
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# === AdSense (apply after launch) ===
NEXT_PUBLIC_ADSENSE_CLIENT=
